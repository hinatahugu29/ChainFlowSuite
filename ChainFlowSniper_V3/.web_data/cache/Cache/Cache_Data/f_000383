<div class="wp-block-column is-vertically-aligned-center" style="flex-basis:33.33%">
<figure class="wp-block-image size-large"><img width="1024" height="681" src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" data-src="https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-1024x681.jpg" alt="" class="wp-image-6631 lazyload" data-srcset="https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-1024x681.jpg 1024w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-300x200.jpg 300w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-768x511.jpg 768w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-1536x1022.jpg 1536w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-2048x1363.jpg 2048w" sizes="(max-width: 1024px) 100vw, 1024px"  data-aspectratio="1024/681"><noscript><img width="1024" height="681" src="https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-1024x681.jpg" alt="" class="wp-image-6631" srcset="https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-1024x681.jpg 1024w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-300x200.jpg 300w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-768x511.jpg 768w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-1536x1022.jpg 1536w, https://www.buffalo.jp/media/wp-content/uploads/2023/10/profile-2048x1363.jpg 2048w" sizes="(max-width: 1024px) 100vw, 1024px" ></noscript></figure>
