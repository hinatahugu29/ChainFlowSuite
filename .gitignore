.dir_index.json
*.pdf
*.png
*.jpg
*.jpeg
*.gif
!app_icon.ico
!chainflow_icon_candidate.png
!chainflow_frameless_candidate.png

# Binaries/Archives
*.exe
*.dll
*.so
*.dylib
*.msi
*.bin
*.zip
*.7z
*.rar
